# Prevents massive payload uploads during gcloud run deploy
# Ignore node_modules (these will be installed by Cloud Build)
node_modules/

# Ignore local build outputs
.next/
out/
build/

# Ignore Git history
.git/
.gitignore

# Ignore environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
